{
  "name": "microfinance-system",
  "version": "1.0.0",
  "description": "Microfinance & Savings Management System with Predictive Analytics and Reporting",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "setup-db": "node scripts/setup-database.js",
    "setup-db-simple": "node scripts/setup-database-simple.js",
    "seed": "node scripts/seed.js",
    "seed-simple": "node scripts/seed-simple.js",
    "setup": "echo 'Setting up database...' && npm run setup-db && echo 'Seeding database...' && npm run seed",
    "build": "echo 'Build completed'",
    "migrate": "node scripts/setup-database.js",
    "reset-db": "mysql -u root -p -e 'DROP DATABASE IF EXISTS microfinance_system; CREATE DATABASE microfinance_system;' && npm run setup-db && npm run seed"
  },
  "keywords": [
    "microfinance",
    "savings",
    "loans",
    "nodejs",
    "express",
    "mysql",
    "predictive-analytics",
    "reporting"
  ],
  "author": "Microfinance System Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.23",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^2.2.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.18.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.14.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/microfinance-system.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/microfinance-system/issues"
  },
  "homepage": "https://github.com/your-org/microfinance-system#readme"
}
