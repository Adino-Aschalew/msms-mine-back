{
  "name": "microfinance-system",
  "version": "1.0.0",
  "description": "Microfinance & Savings Management System with Predictive Analytics and Reporting",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "setup-db": "mysql -u root -p < schema.sql",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "microfinance",
    "savings",
    "loans",
    "nodejs",
    "express",
    "mysql",
    "predictive-analytics",
    "reporting"
  ],
  "author": "Microfinance System Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "csv-parser": "^3.0.0",
    "exceljs": "^4.4.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.14.0",
    "moment": "^2.29.4",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/microfinance-system.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/microfinance-system/issues"
  },
  "homepage": "https://github.com/your-org/microfinance-system#readme"
